NODE_ENV=production
PORT=3000
CLIENT_ORIGIN=https://app.example.com
JWT_SECRET=generate-a-long-random-secret
JWT_EXPIRES_IN=10m
TRUST_PROXY=1
LOGIN_RATE_LIMIT=20
API_RATE_LIMIT=240
JSON_LIMIT=1mb
BACKUP_DIR=./backups

DB_HOST=localhost
DB_PORT=5432
DB_NAME=lasev_db
DB_USER=lasev_user
DB_PASSWORD=generate-a-strong-database-password
DB_SSL=false

SEED_DEV_NAME=Mining Developer
SEED_DEV_PASSWORD=MiningInnovation
SEED_OWNER_NAME=Lasev Owner
SEED_OWNER_PASSWORD=generate-a-strong-owner-password
SEED_RECEPTION_NAME=Lasev Reception
SEED_RECEPTION_PASSWORD=generate-a-strong-reception-password
